<footer class="wrap">
  <span class="footer-logo"><span class="prefix">~/</span>stubborncoder &copy; {new Date().getFullYear()}</span>
  <div class="footer-links">
    <a href="https://github.com/stubborncoder" target="_blank">GitHub</a>
    <a href="https://linkedin.com/in/daviddiaztrapero" target="_blank">LinkedIn</a>
    <a href="https://community.sap.com" target="_blank">SAP Community</a>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border); padding: 3rem 0;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.72rem; color: var(--text-lo);
  }
  .footer-logo .prefix { color: var(--ember); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { color: var(--text-lo); text-decoration: none; }
  .footer-links a:hover { color: var(--ember); }
</style>
